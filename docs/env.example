NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=

# Server-only (do not expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
VMS_API_KEY=

# Default/home venue id in Sim Racing VMS
VMS_HOME_VENUE_ID=1
VMS_VENUE_TIMEZONE=America/New_York

# Contentful Race Radar (server-only)
CONTENTFUL_SPACE_ID=
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_ENVIRONMENT=master

# Optional overrides for legacy/custom Contentful models.
# The app auto-detects common blog content types and field names first.
CONTENTFUL_CONTENT_TYPE=
CONTENTFUL_FIELD_TITLE=
CONTENTFUL_FIELD_SLUG=
CONTENTFUL_FIELD_EXCERPT=
CONTENTFUL_FIELD_COVER_IMAGE=
CONTENTFUL_FIELD_BODY=
CONTENTFUL_FIELD_TAGS=

# Stripe (Merch / One-time purchases)
# Value must be the actual Stripe publishable key, such as pk_live_... or pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Booking reminder SMS (server-only)
CRON_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Toast (paid sim session webhooks)
TOAST_WEBHOOK_SECRET=
TOAST_RESTAURANT_GUID=
TOAST_RACING_ITEM_GUIDS=
TOAST_RACING_CATEGORY_GUIDS=
TOAST_DEFAULT_SESSION_MINUTES=30
TOAST_DEFAULT_SESSION_PODS=1
TOAST_API_BASE_URL=https://ws-api.toasttab.com
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
